# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/backups/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next-dev-*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python bytecode
__pycache__/
*.pyc

# PII / internal findings — this remote is PUBLIC. Raw lead exports and
# review/QA artifacts must never be committable (SEC6-01).
*.csv
reviews/
.claude/reviews/
