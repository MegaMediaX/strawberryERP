# Non-secret deployment settings
NEXT_PUBLIC_APP_NAME=LebTech Partner Platform
PUBLIC_BASE_URL=https://portal.example.com
FRAPPE_BASE_URL=http://backend:8000
FRAPPE_HOST_HEADER=lebtech.local
SITE_NAME=lebtech.local

# Prefer mounted secret files. The application resolves NAME_FILE when NAME is absent.
FRAPPE_API_KEY_FILE=/run/secrets/frappe_api_key
FRAPPE_API_SECRET_FILE=/run/secrets/frappe_api_secret
PORTAL_SESSION_SECRET_FILE=/run/secrets/portal_session_secret
PORTAL_API_KEY_SECRET_FILE=/run/secrets/portal_api_key_secret
API_KEY_HASH_SECRET_FILE=/run/secrets/api_key_hash_secret
SMTP_PASSWORD_FILE=/run/secrets/smtp_password
META_WHATSAPP_ACCESS_TOKEN_FILE=/run/secrets/meta_whatsapp_access_token
WASENDER_API_KEY_FILE=/run/secrets/wasender_api_key
GOOGLE_CALENDAR_CLIENT_SECRET_FILE=/run/secrets/google_calendar_client_secret
GOOGLE_DRIVE_CLIENT_SECRET_FILE=/run/secrets/google_drive_client_secret
MARIADB_ROOT_PASSWORD_FILE=/run/secrets/mariadb_root_password
MARIADB_PASSWORD_FILE=/run/secrets/mariadb_password
# Provider secret name DATABASE_PASSWORD maps to MARIADB_PASSWORD_FILE above.

# Non-secret integration settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_ENCRYPTION=STARTTLS
SMTP_FROM_NAME=LebTech Partner Platform
SMTP_FROM_EMAIL=billing@example.com
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_REDIRECT_URI=https://portal.example.com/profile/integrations/calendar/callback
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_REDIRECT_URI=https://portal.example.com/settings/integrations/google-drive/callback
GOOGLE_DRIVE_CONTRACT_FOLDER_ID=

# Immutable runtime images
ERPNEXT_IMAGE=frappe/erpnext:v15.111.0@sha256:f78d1cdca68f701b4d2c9bf9bfaf720e888b8e21189dfe465a593f7402fe3881
MARIADB_IMAGE=mariadb:10.6.27@sha256:daacc2f260f8ec999daa5e03a017a23a7e6fa3fb982aaf26e8b72f24daf03bc9
REDIS_IMAGE=redis:7-alpine@sha256:8b81dd37ff027bec4e516d41acfbe9fe2460070dc6d4a4570a2ac5b9d59df065
NGINX_IMAGE=nginx:1.27-alpine@sha256:65645c7bb6a0661892a8b03b89d0743208a18dd2f3f17a54ef4b76fb8e2f2a10
GUNICORN_THREADS=4
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
FRAPPE_PORT=8000
NGINX_BIND_ADDRESS=127.0.0.1
NGINX_HTTP_PORT=8080
MARIADB_DATABASE=erpnext
MARIADB_USER=erpnext

# Backup policy. BACKUP_ENCRYPTION_KEY must come from a secret file or manager.
BACKUP_EXPORT_DIR=/var/backups/lebtech-partner-platform/staging
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY_FILE=/run/secrets/backup_encryption_key
OFFHOST_PROVIDER=rclone
OFFHOST_RCLONE_TARGET=production-backups:lebtech-partner-platform
