NEXT_PUBLIC_APP_NAME=LebTech Partner Platform
PUBLIC_BASE_URL=https://portal.example.com

# ERPNext / Frappe
FRAPPE_BASE_URL=http://backend:8000
FRAPPE_HOST_HEADER=lebtech.local
FRAPPE_API_KEY=change-me
FRAPPE_API_SECRET=change-me

# Platform session and API key hashing
PORTAL_SESSION_SECRET=change-this-before-production
PORTAL_API_KEY_SECRET=change-this-before-production
API_KEY_HASH_SECRET=change-this-before-production

# WhatsApp providers
META_WHATSAPP_APP_ID=
META_WHATSAPP_APP_SECRET=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_WABA_ID=
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_VERIFY_TOKEN=
WASENDER_API_KEY=
WASENDER_INSTANCE_ID=
WASENDER_SENDER_NUMBER=

# Google OAuth and storage
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/profile/integrations/calendar/callback
GOOGLE_CALENDAR_DEFAULT_ID=primary
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/settings/integrations/google-drive/callback
GOOGLE_DRIVE_CONTRACT_FOLDER_ID=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_ENCRYPTION=STARTTLS
SMTP_FROM_NAME=LebTech Partner Platform
SMTP_FROM_EMAIL=billing@lebtech.example

# Docker / ERPNext
ERPNEXT_IMAGE=frappe/erpnext:v15.111.0@sha256:f78d1cdca68f701b4d2c9bf9bfaf720e888b8e21189dfe465a593f7402fe3881
MARIADB_IMAGE=mariadb:10.6.27@sha256:daacc2f260f8ec999daa5e03a017a23a7e6fa3fb982aaf26e8b72f24daf03bc9
REDIS_IMAGE=redis:7-alpine@sha256:8b81dd37ff027bec4e516d41acfbe9fe2460070dc6d4a4570a2ac5b9d59df065
NGINX_IMAGE=nginx:1.27-alpine@sha256:65645c7bb6a0661892a8b03b89d0743208a18dd2f3f17a54ef4b76fb8e2f2a10
GUNICORN_THREADS=4
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
FRAPPE_PORT=8000
NGINX_BIND_ADDRESS=0.0.0.0
NGINX_HTTP_PORT=80
MARIADB_ROOT_PASSWORD=change-me
MARIADB_DATABASE=erpnext
MARIADB_USER=erpnext
MARIADB_PASSWORD=change-me
SITE_NAME=lebtech.local

# Backup export staging. Sync this directory to encrypted off-host storage.
BACKUP_EXPORT_DIR=/var/backups/lebtech-partner-platform
BACKUP_RETENTION_DAYS=30

# Seed login passwords (dev bootstrap). Required by `npm test` and the live
# smoke scripts. Set real values in your untracked .env; they must match the
# scrypt hashes seeded in src/lib/auth/credentials.ts. Rotate before deployment.
SEED_ADMIN_PW=change-me
SEED_REGIONAL_PW=change-me
SEED_RESELLER_PW=change-me
SEED_SALES_PW=change-me
