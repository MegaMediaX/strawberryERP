    { "fieldname": "trigger_condition", "fieldtype": "Select", "label": "Trigger Condition", "options": "Invoice Created\nDeposit Paid\nFully Paid", "reqd": 1 },
    { "fieldname": "applies_to", "fieldtype": "Select", "label": "Applies To", "options": "Invoice Total\nReceipt Amount", "default": "Invoice Total" },
    { "fieldname": "is_active", "fieldtype": "Check", "label": "Is Active", "default": 1 },
    { "fieldname": "created_by", "fieldtype": "Link", "label": "Created By", "options": "User" }
