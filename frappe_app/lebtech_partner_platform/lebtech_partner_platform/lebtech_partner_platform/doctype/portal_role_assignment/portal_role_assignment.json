{
  "doctype": "DocType",
  "name": "Portal Role Assignment",
  "module": "LebTech Partner Platform",
  "custom": 0,
  "is_submittable": 0,
  "istable": 0,
  "track_changes": 1,
  "autoname": "format:PRA-{####}",
  "title_field": "user",
  "fields": [
    {
      "fieldname": "user",
      "fieldtype": "Link",
      "label": "User",
      "options": "User",
      "reqd": true
    },
    {
      "fieldname": "role",
      "fieldtype": "Select",
      "label": "Role",
      "options": "Super Admin\nRegional Director\nReseller Admin\nSales Team User",
      "reqd": true
    },
    {
      "fieldname": "assigned_countries",
      "fieldtype": "JSON",
      "label": "Assigned Countries"
    },
    {
      "fieldname": "assigned_reseller",
      "fieldtype": "Link",
      "label": "Assigned Reseller",
      "options": "Reseller"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": 1
