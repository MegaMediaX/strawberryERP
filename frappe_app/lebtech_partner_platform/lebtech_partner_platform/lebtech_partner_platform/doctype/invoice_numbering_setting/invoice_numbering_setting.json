{
  "doctype": "DocType",
  "name": "Invoice Numbering Setting",
  "module": "LebTech Partner Platform",
  "custom": 0,
  "is_submittable": 0,
  "istable": 0,
  "track_changes": 1,
  "autoname": "format:INVNUM-{####}",
  "fields": [
    {
