{
  "doctype": "DocType",
  "name": "Contract",
  "module": "LebTech Partner Platform",
  "custom": 0,
  "is_submittable": 0,
  "track_changes": 1,
  "autoname": "format:CON-{####}",
  "title_field": "customer",
  "fields": [
    { "fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "Customer", "reqd": 1 },
    { "fieldname": "reseller", "fieldtype": "Link", "label": "Reseller", "options": "Reseller", "reqd": 1 },
    { "fieldname": "country", "fieldtype": "Select", "label": "Country", "options": "Lebanon\nCyprus\nJordan\nSyria", "reqd": 1 },
    { "fieldname": "contract_status", "fieldtype": "Select", "label": "Contract Status", "options": "Not Signed\nSigned", "default": "Not Signed" },
    { "fieldname": "storage_provider", "fieldtype": "Select", "label": "Storage Provider", "options": "Google Drive", "default": "Google Drive" },
    { "fieldname": "google_drive_file_id", "fieldtype": "Data", "label": "Google Drive File ID" },
    { "fieldname": "file_url", "fieldtype": "Data", "label": "File URL" },
    { "fieldname": "uploaded_by", "fieldtype": "Link", "label": "Uploaded By", "options": "User" },
    { "fieldname": "uploaded_at", "fieldtype": "Datetime", "label": "Uploaded At" },
    { "fieldname": "generated_from_template", "fieldtype": "Check", "label": "Generated From Template" },
    { "fieldname": "template_used", "fieldtype": "Data", "label": "Template Used" }
  ],
  "permissions": [
    { "role": "Super Admin", "read": 1, "write": 1, "create": 1, "delete": 0 },
    { "role": "Regional Director", "read": 1, "write": 0, "create": 0, "delete": 0 },
    { "role": "Reseller Admin", "read": 1, "write": 1, "create": 1, "delete": 0 },
    { "role": "Sales Team User", "read": 1, "write": 1, "create": 1, "delete": 0 }
  ]
}
