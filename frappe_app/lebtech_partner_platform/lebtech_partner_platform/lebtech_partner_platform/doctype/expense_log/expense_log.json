{
  "doctype": "DocType",
  "name": "Expense Log",
  "module": "LebTech Partner Platform",
  "custom": 0,
  "is_submittable": 0,
  "istable": 0,
  "track_changes": 1,
  "autoname": "format:EXP-{####}",
  "fields": [
    {
      "fieldname": "country",
      "fieldtype": "Select",
      "label": "Country",
      "options": "Lebanon\nCyprus\nJordan\nSyria"
    },
    {
      "fieldname": "reseller",
      "fieldtype": "Link",
      "label": "Reseller",
      "options": "Reseller"
    },
    {
      "fieldname": "category",
      "fieldtype": "Data",
      "label": "Category",
      "reqd": true
    },
    {
      "fieldname": "amount",
      "fieldtype": "Currency",
      "label": "Amount"
    },
    {
      "fieldname": "currency",
      "fieldtype": "Data",
      "label": "Currency"
    },
    {
      "fieldname": "expense_date",
      "fieldtype": "Date",
      "label": "Expense Date"
    },
    {
      "fieldname": "reference",
      "fieldtype": "Data",
      "label": "Reference"
    }
  ],
  "permissions": [
    {
      "role": "Super Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0
    },
    {
      "role": "Regional Director",
      "read": 1,
      "write": 0,
      "create": 0,
      "delete": 0
    },
    {
      "role": "Reseller Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0
    },
    {
      "role": "Sales Team User",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0
    }
  ]
}
