{
  "doctype": "DocType",
  "name": "Call Record",
  "module": "LebTech Partner Platform",
  "custom": 0,
  "is_submittable": 0,
  "track_changes": 0,
  "autoname": "format:CALL-{####}",
  "title_field": "external_id",
  "fields": [
    { "fieldname": "external_id", "fieldtype": "Data", "label": "External ID", "reqd": 1, "unique": 1, "search_index": 1 },
    { "fieldname": "direction", "fieldtype": "Select", "label": "Direction", "options": "outbound\ninbound", "reqd": 1 },
    { "fieldname": "from_number", "fieldtype": "Data", "label": "From Number" },
    { "fieldname": "to_number", "fieldtype": "Data", "label": "To Number" },
    { "fieldname": "contact_number", "fieldtype": "Data", "label": "Contact Number", "reqd": 1 },
    { "fieldname": "outcome", "fieldtype": "Select", "label": "Outcome", "options": "answered\nrang_no_answer", "reqd": 1 },
    { "fieldname": "answered", "fieldtype": "Check", "label": "Answered" },
    { "fieldname": "ring_seconds", "fieldtype": "Int", "label": "Ring Seconds", "default": 0 },
    { "fieldname": "talk_seconds", "fieldtype": "Int", "label": "Talk Seconds", "default": 0 },
    { "fieldname": "duration_seconds", "fieldtype": "Int", "label": "Duration Seconds", "default": 0 },
    { "fieldname": "started_at", "fieldtype": "Datetime", "label": "Started At", "reqd": 1, "search_index": 1 },
    { "fieldname": "recording_file", "fieldtype": "Data", "label": "Recording File" },
    { "fieldname": "account", "fieldtype": "Data", "label": "Account" },
    { "fieldname": "extension", "fieldtype": "Data", "label": "Extension" },
    { "fieldname": "link_state", "fieldtype": "Select", "label": "Link State", "options": "linked\nunlinked", "reqd": 1 },
    { "fieldname": "lead", "fieldtype": "Data", "label": "Lead" },
    { "fieldname": "customer", "fieldtype": "Data", "label": "Customer" },
    { "fieldname": "reseller", "fieldtype": "Data", "label": "Reseller", "search_index": 1 },
    { "fieldname": "country", "fieldtype": "Select", "label": "Country", "options": "Lebanon\nCyprus\nJordan\nSyria", "search_index": 1 },
    { "fieldname": "assigned_to", "fieldtype": "Data", "label": "Assigned To" },
    { "fieldname": "agent", "fieldtype": "Data", "label": "Agent", "search_index": 1 },
    { "fieldname": "acquired_phone", "fieldtype": "Data", "label": "Acquired Phone" },
    { "fieldname": "acquired_email", "fieldtype": "Data", "label": "Acquired Email" },
    { "fieldname": "logged_at", "fieldtype": "Datetime", "label": "Logged At" }
  ],
  "permissions": [
    { "role": "Super Admin", "read": 1, "write": 1, "create": 1, "delete": 1 },
    { "role": "Regional Director", "read": 1, "write": 0, "create": 0, "delete": 0 },
    { "role": "Reseller Admin", "read": 1, "write": 1, "create": 1, "delete": 0 },
    { "role": "Sales Team User", "read": 1, "write": 1, "create": 0, "delete": 0 }
  ]
}
