{
  "doctype": "DocType",
  "name": "Invoice",
  "module": "LebTech Partner Platform",
  "custom": 0,
  "is_submittable": 0,
  "track_changes": 1,
  "autoname": "field:invoice_number",
  "title_field": "invoice_number",
  "fields": [
    { "fieldname": "invoice_number", "fieldtype": "Data", "label": "Invoice Number", "reqd": 1, "unique": 1 },
    { "fieldname": "numbering_mode", "fieldtype": "Select", "label": "Numbering Mode", "options": "Country Prefix\nReseller Prefix\nGlobal Sequence", "default": "Country Prefix" },
    { "fieldname": "country", "fieldtype": "Select", "label": "Country", "options": "Lebanon\nCyprus\nJordan\nSyria", "reqd": 1 },
    { "fieldname": "reseller", "fieldtype": "Link", "label": "Reseller", "options": "Reseller", "reqd": 1 },
    { "fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "Customer", "reqd": 1 },
    { "fieldname": "currency", "fieldtype": "Link", "label": "Currency", "options": "Currency Setting", "reqd": 1 },
    { "fieldname": "subtotal", "fieldtype": "Currency", "label": "Subtotal", "reqd": 1 },
    { "fieldname": "discount", "fieldtype": "Currency", "label": "Discount" },
    { "fieldname": "tax_amount", "fieldtype": "Currency", "label": "Tax Amount" },
    { "fieldname": "total", "fieldtype": "Currency", "label": "Total", "read_only": 1 },
    { "fieldname": "payment_status", "fieldtype": "Select", "label": "Payment Status", "options": "Unpaid\nPartially Paid\nFully Paid\nOverdue", "default": "Unpaid" },
    { "fieldname": "invoice_status", "fieldtype": "Select", "label": "Invoice Status", "options": "Draft\nIssued\nPartially Paid\nFully Paid\nCancelled", "default": "Draft" },
    { "fieldname": "due_date", "fieldtype": "Date", "label": "Due Date" },
    { "fieldname": "generated_pdf_url", "fieldtype": "Data", "label": "Generated PDF URL" },
    { "fieldname": "qr_code_url", "fieldtype": "Data", "label": "QR Code URL" },
    { "fieldname": "payment_link", "fieldtype": "Data", "label": "Payment Link" },
    { "fieldname": "created_by_user", "fieldtype": "Link", "label": "Created By User", "options": "User" },
    { "fieldname": "issued_at", "fieldtype": "Datetime", "label": "Issued At" },
    { "fieldname": "line_items_json", "fieldtype": "JSON", "label": "Line Items JSON" },
    { "fieldname": "custom_fields_json", "fieldtype": "JSON", "label": "Custom Fields" }
  ],
  "permissions": [
    { "role": "Super Admin", "read": 1, "write": 1, "create": 1, "delete": 0 },
    { "role": "Regional Director", "read": 1, "write": 0, "create": 0, "delete": 0 },
    { "role": "Reseller Admin", "read": 1, "write": 1, "create": 1, "delete": 0 },
    { "role": "Sales Team User", "read": 1, "write": 1, "create": 1, "delete": 0 }
  ]
}
