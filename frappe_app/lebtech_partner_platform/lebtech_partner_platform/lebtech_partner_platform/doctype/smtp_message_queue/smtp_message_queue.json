      "delete": 0
    },
    {
      "role": "Reseller Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0
    },
    {
      "role": "Sales Team User",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0
    }
  ]
