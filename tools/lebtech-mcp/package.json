{
  "name": "lebtech-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server exposing the LebTech Partner Platform (portal + Frappe tiers) to AI agents. Wraps existing HTTP surfaces only — zero app-code change.",
  "type": "module",
  "bin": {
    "lebtech-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsc -p tsconfig.json && node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "undici": "^6.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
