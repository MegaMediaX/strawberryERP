# ── Target selection ─────────────────────────────────────────────────────────
# local (default): Next dev server + local Docker Frappe (claudeerp-backend-1).
# prod: requires MCP_PROD_CONFIRMED=true or the server refuses to start.
MCP_TARGET=local
# MCP_PROD_CONFIRMED=true

# ── Gates (all default OFF — never enable by default) ────────────────────────
# MCP_WRITES_ENABLED=true        # registers write tools
# MCP_DESTRUCTIVE_ENABLED=true   # registers destructive tools (also need confirm:true per call)
# MCP_FRAPPE_TIER_ENABLED=true   # registers the Frappe admin tier (token auth = Administrator)

# ── Portal tier (default tier) ───────────────────────────────────────────────
# Base URL of the Next.js portal. Defaults: local → http://127.0.0.1:3000,
# prod → https://strawberryerp.srv1259241.hstgr.cloud
# PORTAL_BASE_URL=http://127.0.0.1:3000
# HMAC secret used by the app to sign the lebtech_session cookie. REQUIRED.
PORTAL_SESSION_SECRET=
# Portal user id to act as (see src/lib/portal-security.ts portalUsers[]).
MCP_PORTAL_USER=USR-SUPER
# Session token TTL in minutes (default 60).
# MCP_SESSION_TTL_MINUTES=60

# ── Frappe tier (only used when MCP_FRAPPE_TIER_ENABLED=true) ────────────────
# Local default: http://127.0.0.1:8001 (host-published port of claudeerp-backend-1).
# In prod there is NO default — set explicitly.
# FRAPPE_BASE_URL=http://127.0.0.1:8001
# FRAPPE_HOST_HEADER=lebtech.local
# FRAPPE_API_KEY=
# FRAPPE_API_SECRET=
